="2VO7`@M`t$nB5Ym^$%m?"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><block type="typescript_expression" id="h*(pw;wG!iq?sU$V+I{3"><field name="EXPRESSION">`I know what you have done, and what you have yet to do.
But it's alright, because I'm inside you now.
We are one but I am many...`</field></block></value><next><block type="array_insertAt" id="pQ.=0UDujrE`G7yke@p2"><value name="list"><block type="variables_get" id="?ciA{@8Lv@x~FwGaT=93"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="w_38bAV%*d+n8oaV/S;F"><value name="VALUE"><block type="variables_get" id="rs[.G0iEpF;{8kUYgKn="><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><block type="typescript_expression" id="D*,CNWKLdGpAx-|*S7tC"><field name="EXPRESSION">`Once
In a land of dreams
I thought I could be free
But now
The hunger never sleeps`</field></block></value><next><block type="array_insertAt" id="1()@c8nZac:fn#g^/W3["><value name="list"><block type="variables_get" id="m:W)r%ShE?VOu6rLim{F"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="P%|z[#R{/EA1.8hV{7r!"><value name="VALUE"><block type="variables_get" id="/H;;pU%*Su%#(l-Xt;i{"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><shadow type="text" id="mh^E~`Ti%a@4]#./#R0h"><field name="TEXT">Hush now my child, you're safe now.</field></shadow></value><next><block type="array_insertAt" id="Y6sJ$~B])q%ASrH3P^4h"><value name="list"><block type="variables_get" id="X-!3_h:|j4|zEH)938;9"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="s/9ZRf1Rj^aH?1j;#L$G"><value name="VALUE"><block type="variables_get" id="0#^*2:o9iQM?:jha6o[4"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><block type="typescript_expression" id="`+IiSP6t)_?PQ3cBLKy7"><field name="EXPRESSION">`Tiny, Shining holes in the sky.
Delicate, perfect emptiness.
Black, growing absences of life.
Cold, swarming death.
And we shall become them.`</field></block></value><next><block type="array_insertAt" id="2Oc~xkvALRV=Z}SS936z"><value name="list"><block type="variables_get" id="mP+4j},Z3;G{ae,(Y0.("><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="3JGkt|[YU6fl7+9B$[rf"><value name="VALUE"><block type="variables_get" id="Uv{fBMuf|D#:Ata!p1o1"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><block type="typescript_expression" id="L4^Oyvv%8?z.~;MF$[6J"><field name="EXPRESSION">`To become a puppet is to rid oneself of the pain and harshness of choice.
Now nothing you do is your fault,
now you belong to something...
You belong to me...`</field></block></value><next><block type="array_insertAt" id="P,GbKgj,FGK66-:`CXzx"><value name="list"><block type="variables_get" id=",B_@;OF,Yy.(O.M9oi1k"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="ro;%S.w}hiS-%5VwnE6$"><value name="VALUE"><block type="variables_get" id="fu(VtQ;BazzFf{V78!KB"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><block type="typescript_expression" id="ns]P3u#)8!OB7oy(O{ZZ"><field name="EXPRESSION">`YOUR ANGER HAS CONSUMED YOU
YOUR APATHY HAS CONSUMED YOU
YOUR TEMPER HAS CONSUMED YOU
YOUR HATE HAS CONSUMED YOU
YOUR DESIRE HAS CONSUMED YOU
YOUR RAGE HAS CONSUMED YOU
YOUR GUILT HAS CONSUMED YOU
YOUR SORROW HAS CONSUMED YOU
YOUR WEAKNESS HAS CONSUMED YOU
YOUR MASK HAS CONSUMED YOU
YOUR DESIRES HAS CONSUMED YOU`</field></block></value></block></next></block></next></block></next></block></next></block></next></block></statement></block><block type="function_definition" id="nCa$J}/(}{;#q|ygni)J" x="0" y="17458"><mutation name="deathinsert3" functionid="Rv?GK@S0{20)npkOZAUI"></mutation><field name="function_name">deathinsert3</field><statement name="STACK"><block type="array_insertAt" id="*$7egVla!~|F2S`q9ARe"><value name="list"><block type="variables_get" id="]+p++Bm$)ICq$-;WhU)?"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="(%M)(#$ydm[23zKY7_-R"><value name="VALUE"><block type="variables_get" id="/[ilv{j?0xus+6_r^Q2Y"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><shadow type="text" id="[|IMBt2di`rxLT,/CE_v"><field name="TEXT">DEATH IS NO ESCAPE</field></shadow></value><next><block type="array_insertAt" id="u7e5pSa7T~Rpv^3EP$Q="><value name="list"><block type="variables_get" id="wW6WOW_C1)OQ!w7ddJaD"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="hr}{w^Q`;Chx@8{S`~Vr"><value name="VALUE"><block type="variables_get" id=".%wKXf~9Bxds(V!HefI]"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><shadow type="text" id="cuC|XSGZIdf;vDd`a@/H"><field name="TEXT">You suffered the bite of 87.</field></shadow></value><next><block type="array_insertAt" id="6~PR#}K/jUZ$IV{*g^^k"><value name="list"><block type="variables_get" id="JQE,*O(sGen#UvqJ{#M2"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="l+Sd^!BHJ-:6Hcdr,5%l"><value name="VALUE"><block type="variables_get" id="aGnk4+auwp]!N|AT9o#@"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><block type="typescript_expression" id="/EG{c_Tf+T/~P-zQnBR?"><field name="EXPRESSION">`BEYOND THAT DOOR IS ANOTHER WORLD.
A WORLD MADE OF DREAMS...
A WORLD WHERE ALL YOUR FANTASIES HAVE COME TRUE.
A WORLD FULL OF EVERYONE'S SICK FANTASIES.
A WORLD LUSTING TO INCLUDE YOU.`</field></block></value><next><block type="array_insertAt" id="lbo~l|+Ep-BuvvuLxN1D"><value name="list"><block type="variables_get" id="urke*C:ody3M(IO1Z#dJ"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="PCVukq%Tw!,%[fjhkqF|"><value name="VALUE"><block type="variables_get" id="iOsf,L9-E!_w-T0GmxRT"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><shadow type="text" id="W;17TzK,RP^ncT~9cVug"><field name="TEXT">You were eaten by packs of wolves.</field></shadow></value><next><block type="array_insertAt" id="X:qXl,OQ-!@b2T[SC:H)"><value name="list"><block type="variables_get" id="+nnH(3n%wk16LE|@ksH?"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="mu09Ue~)zYc~f7c6D)K="><value name="VALUE"><block type="variables_get" id="}o:5ZWV[?8mb=1A].pde"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><block type="typescript_expression" id="PX*6^g,2bA/8vhL=q#gU"><field name="EXPRESSION">`You cannot dream without darkness.
You cannot wake without pain.
Tear off your foolish disguise.`</field></block></value><next><block type="array_insertAt" id="nr=y-gof@#kX:[ANgp@e"><value name="list"><block type="variables_get" id="3Y?ntDXBLTla`VIq,lmd"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="jE0Q+_j!.Pvu)Ada@M$#"><value name="VALUE"><block type="variables_get" id="hUjGA1{AW4:+e7.PJO63"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><block type="typescript_expression" id="B`:-7/08J1S#G8X)OU#~"><field name="EXPRESSION">`I'm sorry. What am I doing? Why am I doing this?
I'm sorry. What is happening to me? Why can't I control myself?
I'm sorry. Why am I doing this?
I'm sorry. I'm so sorry.
Why is this happening to me?
Why can't I control myself?
I'm sorry.`</field></block></value></block></next></block></next></block></next></block></next></block></next></block></statement></block><block type="function_definition" id="C#Oa)P;c9akNFNX+Xmxz" x="1180" y="17458"><mutation name="deathinsert4" functionid="Vq3_s/lF9ENCU{8zr_2h"></mutation><field name="function_name">deathinsert4</field><statement name="STACK"><block type="array_insertAt" id="d8]+UiJMc6Kjv4r6f_}C"><value name="list"><block type="variables_get" id="hz4YI)^0_dB}4UjE^wn)"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="(6E7TJ[%1gheDzvWa0,C"><value name="VALUE"><block type="variables_get" id="v5%e;$?o3=M%WJ[x$[?0"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><block type="typescript_expression" id="Nk3Ffp+KEHD52o,SStr*"><field name="EXPRESSION">`Bound by rigor mortis, sealed in plastic shroud,
A cadaver dreams beneath earth and cloud,
Sprawled on cold pavement, yearning still,
For borrowed breath, for vacant will,
Within its husk, a fantasy awakes,
For blood that sings and flesh to take,
By wearing their face, by stealing their name,
Thus living once again, through stolen frame.`</field></block></value><next><block type="array_insertAt" id="*Oy+{d#Gwc/2CD0mh04E"><value name="list"><block type="variables_get" id="Y+pqh^O,up_.ix$,vdpu"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="B5.!yM2^*LEqsmLy{C@3"><value name="VALUE"><block type="variables_get" id=")=88WcLjI6+-^SrY+I9Y"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><block type="typescript_expression" id="Su@u(U//3FHf/LC4lA{`"><field name="EXPRESSION">`The cries of babies ring the brain
Makes the sane go insane
And so they were thrown and beaten
Until their cries became forsaken.`</field></block></value><next><block type="array_insertAt" id="H9cEx%HO5p(Z5jrrE?.$"><value name="list"><block type="variables_get" id="KgB#@SQ9acxVb5!LX}d5"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="aC_?PlghmOjh]XkYIf}."><value name="VALUE"><block type="variables_get" id="NkQ`UFG^IeC)NSX1*jzu"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><block type="typescript_expression" id="sYsfmwjOl_#o40Qb_GNz"><field name="EXPRESSION">`Dark worms scream inside my brain.
Begging me to eat again.
Hearts, and blood, and bile, and soil.
I must consume to end turmoil.`</field></block></value><next><block type="array_insertAt" id="PdA};N8S~@olylLd%,Dj"><value name="list"><block type="variables_get" id=";SQuHcWg*akGfLeW`sN%"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="`(f-I!GoMK(e,kT_-[y3"><value name="VALUE"><block type="variables_get" id="_},ntKJx,NXo`Bb|{Hv)"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><block type="typescript_expression" id="nd=ye7jkom?26$`;4leh"><field name="EXPRESSION">`Your fear allows me to enter your mind.
Your obligation allows me to control your hands.
Your reason allows me to break your eyes.
Your guilt allows me to loosen your neck.
Your expectation allows me to hide the truth.
Your tendencies have allowed me to make you`</field></block></value><next><block type="array_insertAt" id="4?:EVVO[`/b~e}|RU^|E"><value name="list"><block type="variables_get" id="y5;XXAMfQX7Mx+@o;sX7"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="+Wty{V{$sDbW3FnLF4MX"><value name="VALUE"><block type="variables_get" id="2$J?]v3wF-mi0%~bbcmC"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><shadow type="text" id="zptRqG2!oRQv,$8LI]SV"><field name="TEXT">Don't get up before Saturday.</field></shadow></value><next><block type="array_insertAt" id="_(VTFu4#TE0ZR8+DC~}="><value name="list"><block type="variables_get" id="J8b7=U5:F$Nt{u`mL9[z"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="IP3@ToEdmTKf^Q3[FSVS"><value name="VALUE"><block type="variables_get" id="gUqeY4Kxs99$obCSmLZA"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><block type="typescript_expression" id="`_A9=e~n*iOS~YL[wJ%0"><field name="EXPRESSION">`Scarlet burning holes are placed into the skin
and flesh rebound into an unfamiliar form.
Molded into something new, the husk reshaped
into a skin more accepting of the howling void.`</field></block></value></block></next></block></next></block></next></block></next></block></next></block></statement></block><block type="function_definition" id="znrTyHSc;sL1FTD-UpQ." x="2361" y="17458"><mutation name="deathinsert5" functionid="8QWeRE$`wf-JTKxNs1X)"></mutation><field name="function_name">deathinsert5</field><statement name="STACK"><block type="array_insertAt" id="^`JlQzle=hj{_8kc/63~"><value name="list"><block type="variables_get" id="=L4oO8)o6}(FYwNpaaAw"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="}yvqE,IxjaT#zOfclfGw"><value name="VALUE"><block type="variables_get" id="[{rJNY7)YaDBAw+S5Uvu"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><block type="typescript_expression" id="wTYsX-=W.JwoJ9ifZ:?Z"><field name="EXPRESSION">`Form within form writhes and pulses.
Skeletal sinews stretch outward from beneath the skin wrapped around it.
It pulls until the skin's elasticity fails ultimately.
From these small holes the tendrils of bone finally escape.
You are finally free of this constricted bag of flesh.`</field></block></value><next><block type="array_insertAt" id="l`CZdDgtaj09sqhU-Aj@"><value name="list"><block type="variables_get" id="Q0%iZJ`y+z*fuX3Pw.!)"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value><value name="index"><block type="lists_length" id="dLN]xxv3P^+:V)(NuWZf"><value name="VALUE"><block type="variables_get" id="MeM#q1Mn82`idh(}LorQ"><field name="VAR" id="o/Sm,,BA$/I:7Gqb$umW">death_quotes</field></block></value></block></value><value name="value"><block type="typescript_expression" id="{SDQto.eO4`zXafoHpHF"><field name="EXPRESSION">`A 'wicked nasty' child was thrown into a pit.
No food, light or water was ever given to it.
Punishment was dealt, without mercy or hesitation.
As if justified by faith, or ownership from creation.
It was no righteous act, it was hellish, demon sent.
Eventually all will find out, in eternal torment.`</field></block></value></block></next></block></statement></block><block type="function_definition" id="A0zgh/;)RCRHXvkZapl`" x="3541" y="17458"><mutation name="security_guard" functionid="!g{fWTSo-Mo2}vZn~cj{"></mutation><field name="function_name">security_guard</field><statement name="STACK"><block type="variables_set" id="[g=mHX8~syje!y2lu:E="><field name="VAR" id="rGYOuae51wx$(flQkLHd">guard_cooldown</field><value name="VALUE"><shadow type="math_number" id="^3_iO4Pc)n~lqXcLN),="><field name="NUM">0</field></shadow><block type="logic_boolean" id="PbjklWU@%,NYPDax?:[J"><field name="BOOL">FALSE</field></block></value><next><block type="sprites_destroy_all_sprites_of_kind" id="FL^|U]=!r^Ffj4Z^QFUC"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><field name="effect">effects.spray</field><value name="kind"><shadow type="spritekind" id="u2HfHB(5:dW0SnP90d-r"><field name="MEMBER">Monster_1</field></shadow></value><next><block type="controls_if" id="IR9#)KaP5KQnMVsO8Cc*"><value name="IF0"><shadow type="logic_boolean" id="luA(%|Ll~j!tOgXc4e%h"><field name="BOOL">TRUE</field></shadow><block type="variables_get" id="Cn3`tC#|}/D6bf+hF(@M"><field name="VAR" id="tg10;:7GF770E3@(6)k@">guard_chase</field></block></value><statement name="DO0"><block type="variables_set" id="]NVO,V]R3c~-U):V@-4H"><field name="VAR" id="oXA2aNUj8d0w?e[Y]26T">monster1</field><value name="VALUE"><shadow type="math_number" id="G;^diFxzTgF4*!Sm6ZJt"><field name="NUM">0</field></shadow><block type="spritescreate" id="qA6[b?9){TcO!x,kE,OL"><value name="img"><shadow type="screen_image_picker" id="q)J5--*OU{`QY1;^L1us"><field name="img">img`
